configuration {
    modi:                       "drun,run";
    show-icons:                 true;
    icon-theme:                 "Papirus-Dark";
    display-drun:               "";
    drun-display-format:        "{name}";
    font:                       "JetBrainsMono Nerd Font 11";
    hide-scrollbar:             true;
}

@theme "/dev/null"

* {
    bg:         #0d0d0dee;
    bg-alt:     #1a1a1acc;
    fg:         #e0e0e0;
    fg-dim:     #6b6b6b;
    selected:   #2a2a2acc;
    border:     #2e2e2e40;
    accent:     #d8d8d8;

    background-color:  transparent;
    text-color:         @fg;
}

window {
    transparency:                "real";
    background-color:            @bg;
    text-color:                  @fg;
    border:                      1px;
    border-color:                @border;
    border-radius:                14px;
    width:                        480px;
    location:                    center;
    anchor:                      center;
    padding:                     4px;
}

mainbox {
    background-color:            transparent;
    children:                    [ inputbar, listview ];
    spacing:                     8px;
    padding:                     10px;
}

inputbar {
    background-color:            transparent;
    text-color:                  @fg;
    children:                    [ prompt, entry ];
    padding:                     8px 10px;
    spacing:                     8px;
    border:                      0px 0px 1px 0px;
    border-color:                @border;
}

prompt {
    background-color:            transparent;
    text-color:                  @fg-dim;
}

entry {
    background-color:            transparent;
    text-color:                  @fg;
    placeholder:                 "Search...";
    placeholder-color:           @fg-dim;
    cursor:                      text;
}

listview {
    background-color:            transparent;
    columns:                     1;
    lines:                       6;
    spacing:                     2px;
    cycle:                       true;
    dynamic:                     true;
    scrollbar:                   false;
}

element {
    background-color:            transparent;
    text-color:                  @fg;
    padding:                     8px 10px;
    border-radius:                8px;
    orientation:                 horizontal;
    spacing:                     10px;
}

element normal.normal {
    background-color:            transparent;
    text-color:                  @fg;
}

element selected.normal {
    background-color:            @selected;
    text-color:                  @accent;
}

element-icon {
    background-color:            transparent;
    size:                        20px;
    vertical-align:              0.5;
}

element-text {
    background-color:            transparent;
    text-color:                  inherit;
    vertical-align:              0.5;
}

textbox {
    background-color:            transparent;
    text-color:                  @fg;
}
